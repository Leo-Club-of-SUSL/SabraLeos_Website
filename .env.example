# 🦁 Leo Club of SUSL - Environment Templates
# Copy this file to .env and fill in the values

# ----------------------------------------------------------------
# 1. Supabase (Database & Auth)
# Get these from: Supabase Dashboard > Settings > API
# ----------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------------
# 2. Cloudinary (Media Hosting)
# Get these from: Cloudinary Dashboard
# ----------------------------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ----------------------------------------------------------------
# 3. Public URL & Settings
# ----------------------------------------------------------------
VITE_BASE_URL=https://sabraleos.org

# ----------------------------------------------------------------
# 4. Google Analytics 4 (Netlify Functions)
# These are used by netlify/functions/analytics.mts
# ----------------------------------------------------------------
GA4_PROPERTY_ID=your_property_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# IMPORTANT: For the private key, wrap it in "quotes" and ensure \n is preserved
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
